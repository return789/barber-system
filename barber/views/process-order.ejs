<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>处理订单 - 理发会员管理系统</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand" href="/">理发会员管理系统</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/">
              <i class="fas fa-home me-1"></i> 首页
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/members">
              <i class="fas fa-users me-1"></i> 会员管理
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/appointments">
              <i class="fas fa-calendar-alt me-1"></i> 预约管理
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/transactions">
              <i class="fas fa-receipt me-1"></i> 消费记录
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" aria-current="page" href="/orders">
              <i class="fas fa-shopping-cart me-1"></i> 订单管理
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/balance">
              <i class="fas fa-wallet me-1"></i> 余额管理
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/stats">
              <i class="fas fa-chart-bar me-1"></i> 数据统计
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link logout-link" href="/logout" onclick="return confirmAction(this, '确定要退出登录吗？', 'logout');">
              <i class="fas fa-sign-out-alt me-1"></i> 退出登录
            </a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container orders-container">
    <div class="orders-header">
      <div>
        <h1 class="orders-page-title">处理订单</h1>
        <p class="orders-subtitle">确认订单信息并完成处理</p>
      </div>
      <div>
        <a href="/orders" class="btn btn-secondary">
          <i class="fas fa-arrow-left me-1"></i> 返回订单管理
        </a>
      </div>
    </div>

    <div class="process-layout">
      <div class="process-order-card">
        <div class="process-order-card-bg"></div>
        <div class="process-order-card-bg2"></div>

        <div class="process-order-id">
          <i class="fas fa-hashtag me-1"></i> 订单编号 #<%= transaction.id %>
        </div>

        <div class="process-order-amount-section">
          <div class="process-order-amount-label">订单金额</div>
          <div class="process-order-amount-value">¥<%= transaction.amount.toFixed(2) %></div>
        </div>

        <div class="process-order-details">
          <div class="process-order-detail-item">
            <span class="process-order-detail-label">会员姓名</span>
            <span class="process-order-detail-value"><%= transaction.member_name %></span>
          </div>
          <div class="process-order-detail-item">
            <span class="process-order-detail-label">服务日期</span>
            <span class="process-order-detail-value"><%= transaction.date %></span>
          </div>
          <div class="process-order-detail-item">
            <span class="process-order-detail-label">服务描述</span>
            <span class="process-order-detail-value"><%= transaction.description || '-' %></span>
          </div>
          <div class="process-order-detail-item">
            <span class="process-order-detail-label">当前状态</span>
            <span class="process-order-status process-order-status-pending">
              <i class="fas fa-circle"></i> <%= transaction.status %>
            </span>
          </div>
        </div>
      </div>

      <div class="process-action-card">
        <div class="process-action-title">
          <i class="fas fa-credit-card"></i> 处理确认
        </div>
        <p class="process-action-desc">确认处理此订单后，将自动从会员余额中扣除相应金额。请核实金额信息后确认处理。</p>

        <form action="/orders/process/<%= transaction.id %>" method="post">
          <div class="process-amount-section">
            <label for="amount" class="process-amount-label">确认金额</label>
            <div class="process-amount-wrap">
              <span class="process-amount-prefix">¥</span>
              <input type="number" class="form-control process-amount-input" id="amount" name="amount" value="<%= transaction.amount %>" step="1" min="0" required>
            </div>
          </div>

          <div class="process-preview" id="balance_preview">
            <span class="process-preview-label">将从会员余额扣除</span>
            <span class="process-preview-value" id="preview_amount">¥<%= transaction.amount.toFixed(2) %></span>
          </div>

          <div class="process-actions">
            <button type="submit" class="btn btn-success process-confirm-btn">
              <i class="fas fa-check me-1"></i> 确认处理
            </button>
            <a href="/orders" class="btn btn-secondary process-cancel-btn">
              <i class="fas fa-times me-1"></i> 取消
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <footer class="footer">
    <div class="container text-center">
      <p>&copy; 2026 理发会员管理系统</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var amountInput = document.getElementById('amount');
      var previewAmount = document.getElementById('preview_amount');

      amountInput.addEventListener('input', function() {
        var val = parseFloat(amountInput.value);
        if (isNaN(val) || val < 0) {
          previewAmount.textContent = '¥0.00';
        } else {
          previewAmount.textContent = '¥' + val.toFixed(2);
        }
      });
    });
  </script>
  <script src="/confirm.js"></script>
</body>
</html>
