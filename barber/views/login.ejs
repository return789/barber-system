<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>登录 - 理发会员管理系统</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary-color: #C9A067;
      --accent-color: #B8860B;
      --light-color: #FAFAF5;
      --dark-color: #2C2C2C;
      --text-color: #3C3C3C;
      --text-light: #7C7C7C;
    }
    
    body {
      font-family: 'Noto Sans SC', 'Microsoft YaHei', sans-serif;
      background: linear-gradient(135deg, #2C2C2C 0%, #3C3C3C 50%, #2C2C2C 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .login-container {
      background: white;
      border-radius: 24px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.3);
      padding: 50px;
      width: 100%;
      max-width: 460px;
      position: relative;
      overflow: hidden;
      border: 2px solid rgba(201, 160, 103, 0.25);
    }
    
    .login-container::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 5px;
      background: linear-gradient(90deg, #C9A067, #B8860B, #C9A067);
    }
    
    .login-header {
      text-align: center;
      margin-bottom: 40px;
    }
    
    .login-header h1 {
      font-size: 1.7rem;
      font-weight: 600;
      color: var(--dark-color);
      margin-bottom: 12px;
      letter-spacing: 0.5px;
    }
    
    .login-header p {
      color: var(--text-light);
      font-size: 0.95rem;
    }
    
    .login-header i {
      color: var(--primary-color);
      font-size: 1.8rem;
      margin-right: 10px;
    }
    
    .form-control {
      border: 1.5px solid rgba(201, 160, 103, 0.35);
      border-radius: 14px;
      padding: 14px 16px;
      font-size: 1rem;
      transition: all 0.3s ease;
      background-color: white;
    }
    
    .form-control:focus {
      border-color: var(--primary-color);
      box-shadow: 0 0 0 0.15rem rgba(201, 160, 103, 0.25);
    }
    
    .btn-primary {
      background: linear-gradient(135deg, #C9A067, #B8860B);
      border: none;
      padding: 14px;
      font-weight: 600;
      border-radius: 14px;
      transition: all 0.3s ease;
      box-shadow: 0 5px 18px rgba(201, 160, 103, 0.45);
      color: #2C2C2C;
      font-size: 1rem;
    }
    
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(201, 160, 103, 0.55);
      color: #FAFAF5;
    }
    
    .form-label {
      font-weight: 600;
      color: var(--dark-color);
      margin-bottom: 10px;
      font-size: 0.95rem;
    }
    
    .input-group-text {
      background: linear-gradient(135deg, #F5F5F0, #FAFAF5);
      border: 1.5px solid rgba(201, 160, 103, 0.35);
      border-right: none;
      border-radius: 14px 0 0 14px;
      color: var(--primary-color);
    }
    
    .input-group .form-control {
      border-left: none;
      border-radius: 0 14px 14px 0;
    }
    
    .alert {
      border-radius: 12px;
      padding: 14px;
      border: none;
      background: linear-gradient(135deg, rgba(184, 106, 106, 0.25), rgba(184, 106, 106, 0.1));
      color: #6A4A4A;
    }
    
    @media (max-width: 768px) {
      .login-container {
        padding: 35px;
        margin: 20px;
      }
      
      .login-header h1 {
        font-size: 1.4rem;
      }
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-header">
      <h1><i class="fas fa-cut"></i> 理发会员管理系统</h1>
      <p>请登录以访问系统</p>
    </div>
    
    <% if (error) { %>
      <div class="alert" role="alert">
        <i class="fas fa-exclamation-circle me-1"></i> <%= error %>
      </div>
    <% } %>
    
    <form action="/login" method="post">
      <div class="mb-5">
        <label for="username" class="form-label">用户名</label>
        <div class="input-group">
          <span class="input-group-text"><i class="fas fa-user"></i></span>
          <input type="text" class="form-control" id="username" name="username" required>
        </div>
      </div>
      
      <div class="mb-5">
        <label for="password" class="form-label">密码</label>
        <div class="input-group">
          <span class="input-group-text"><i class="fas fa-lock"></i></span>
          <input type="password" class="form-control" id="password" name="password" required>
        </div>
      </div>
      
      <button type="submit" class="btn btn-primary w-100">
        <i class="fas fa-sign-in-alt me-1"></i> 登录
      </button>
    </form>
  </div>
</body>
</html>