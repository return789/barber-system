<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>添加会员 - 理发会员管理系统</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand" href="/">理发会员管理系统</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/">
              <i class="fas fa-home me-1"></i> 首页
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" aria-current="page" href="/members">
              <i class="fas fa-users me-1"></i> 会员管理
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/appointments">
              <i class="fas fa-calendar-alt me-1"></i> 预约管理
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/transactions">
              <i class="fas fa-receipt me-1"></i> 消费记录
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/orders">
              <i class="fas fa-shopping-cart me-1"></i> 订单管理
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/balance">
              <i class="fas fa-wallet me-1"></i> 余额管理
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/stats">
              <i class="fas fa-chart-bar me-1"></i> 数据统计
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link logout-link" href="/logout" onclick="return confirmAction(this, '确定要退出登录吗？', 'logout');">
              <i class="fas fa-sign-out-alt me-1"></i> 退出登录
            </a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container member-form-container">
    <div class="member-form-header">
      <div>
        <h1 class="member-form-page-title">添加会员</h1>
        <p class="member-form-subtitle">填写新会员的个人信息与等级</p>
      </div>
      <div class="member-form-header-actions">
        <a href="/members" class="btn btn-secondary member-form-back-btn">
          <i class="fas fa-arrow-left me-1"></i> 返回列表
        </a>
      </div>
    </div>

    <div class="member-form-layout">
      <div class="member-form-card">
        <form action="/members/add" method="POST">
          <div class="member-form-section">
            <h3 class="member-form-section-title">
              <i class="fas fa-user-circle"></i> 基本信息
            </h3>
            <div class="member-form-grid">
              <div class="member-form-field">
                <label for="name" class="member-form-label">姓名</label>
                <input type="text" class="form-control member-form-input" id="name" name="name" placeholder="请输入会员姓名" required>
              </div>
              <div class="member-form-field">
                <label for="phone" class="member-form-label">电话</label>
                <input type="tel" class="form-control member-form-input" id="phone" name="phone" placeholder="请输入联系电话" required>
              </div>
              <div class="member-form-field">
                <label for="birthdate" class="member-form-label">生日</label>
                <input type="date" class="form-control member-form-input" id="birthdate" name="birthdate">
              </div>
            </div>
          </div>

          <div class="member-form-section">
            <h3 class="member-form-section-title">
              <i class="fas fa-crown"></i> 会员等级
            </h3>
            <input type="hidden" id="membership_level" name="membership_level" value="普通">
            <div class="level-picker">
              <div class="level-picker-card level-picker-normal active" data-value="普通" onclick="selectLevel(this)">
                <div class="level-picker-icon">
                  <i class="fas fa-user"></i>
                </div>
                <div class="level-picker-info">
                  <span class="level-picker-name">普通会员</span>
                  <span class="level-picker-desc">基础会员权益</span>
                </div>
                <div class="level-picker-check">
                  <i class="fas fa-check-circle"></i>
                </div>
              </div>
              <div class="level-picker-card level-picker-gold" data-value="黄金" onclick="selectLevel(this)">
                <div class="level-picker-icon">
                  <i class="fas fa-crown"></i>
                </div>
                <div class="level-picker-info">
                  <span class="level-picker-name">黄金会员</span>
                  <span class="level-picker-desc">专属折扣与优先预约</span>
                </div>
                <div class="level-picker-check">
                  <i class="fas fa-check-circle"></i>
                </div>
              </div>
              <div class="level-picker-card level-picker-diamond" data-value="钻石" onclick="selectLevel(this)">
                <div class="level-picker-icon">
                  <i class="fas fa-gem"></i>
                </div>
                <div class="level-picker-info">
                  <span class="level-picker-name">钻石会员</span>
                  <span class="level-picker-desc">最高尊享礼遇与特权</span>
                </div>
                <div class="level-picker-check">
                  <i class="fas fa-check-circle"></i>
                </div>
              </div>
            </div>
          </div>

          <div class="member-form-actions">
            <button type="submit" class="btn btn-primary member-form-submit-btn">
              <i class="fas fa-plus me-1"></i> 添加会员
            </button>
            <a href="/members" class="btn btn-secondary member-form-cancel-btn">取消</a>
          </div>
        </form>
      </div>

      <div class="member-form-preview-card">
        <div class="member-form-preview-avatar">
          <i class="fas fa-user-plus"></i>
        </div>
        <h4 class="member-form-preview-title">新会员预览</h4>
        <p class="member-form-preview-desc">填写左侧表单后，新会员将立即加入系统</p>
        <div class="member-form-preview-tips">
          <div class="member-form-preview-tip">
            <i class="fas fa-check-circle"></i>
            <span>初始积分为 0</span>
          </div>
          <div class="member-form-preview-tip">
            <i class="fas fa-check-circle"></i>
            <span>初始余额为 ¥0.00</span>
          </div>
          <div class="member-form-preview-tip">
            <i class="fas fa-check-circle"></i>
            <span>可在添加后修改余额与积分</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="footer">
    <div class="container text-center">
      <p>&copy; 2026 理发会员管理系统</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function selectLevel(el) {
      document.querySelectorAll('.level-picker-card').forEach(c => c.classList.remove('active'));
      el.classList.add('active');
      document.getElementById('membership_level').value = el.dataset.value;
    }
  </script>
  <script src="/confirm.js"></script>
</body>
</html>
